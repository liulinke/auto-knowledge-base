# Copy this file to .env and fill in your keys.
# .env is git-ignored and loaded automatically at startup.

# OpenAI API key — used by the LLM (topic optimization, keywords, summaries)
OPENAI_API_KEY=sk-...

# Tavily API key — used by the web search backend
TAVILY_API_KEY=tvly-...

# --- Optional overrides ---------------------------------------------------

# Storage root for all knowledge bases (default: ./kb_data)
# AUTO_KB_DATA_ROOT=kb_data

# LLM model name (default: gpt-4o-mini)
# AUTO_KB_MODEL=gpt-4o-mini

# --- LLM debugging / tracing (only needed for --debug langfuse) -------------

# Langfuse server credentials — create a project in the Langfuse web UI
# (http://localhost:3000 for the self-hosted Docker setup) and copy the keys.
# See docs/llm-debugging.md for the full guide.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000
